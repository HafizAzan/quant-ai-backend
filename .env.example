APP_NAME=QuantAI
APP_ENV=development
API_V1_PREFIX=/api/v1
DEBUG=true

# --- Core (required) ---
DATABASE_URL=postgresql+asyncpg://quantai:quantai@localhost:5432/quantai
DATABASE_URL_SYNC=postgresql+psycopg://quantai:quantai@localhost:5432/quantai
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Encrypt exchange API keys at rest (falls back to JWT_SECRET_KEY if empty)
FERNET_SECRET_KEY=

CORS_ORIGINS=http://localhost:3000
BCRYPT_ROUNDS=12

# --- LLM (priority when LLM_PROVIDER=auto: OpenAI → Cursor) ---
LLM_PROVIDER=auto
# Cursor (available now) — Dashboard → Integrations → API key
CURSOR_API_KEY=crsr_f83495378c4471ff78cc5ab6ee55c9c99070004f79d8abbcd66090c4c6230af7
CURSOR_MODEL=composer-2.5
# Optional workspace for Cursor local agent (defaults to repo root)
CURSOR_CWD=
# OpenAI (optional later)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Celery (optional; defaults to REDIS_URL) ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
