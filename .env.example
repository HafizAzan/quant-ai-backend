APP_NAME=QuantAI
APP_ENV=development
API_V1_PREFIX=/api/v1
DEBUG=true

DATABASE_URL=postgresql+asyncpg://quantai:quantai@localhost:5432/quantai
DATABASE_URL_SYNC=postgresql+psycopg://quantai:quantai@localhost:5432/quantai
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:3000

BCRYPT_ROUNDS=12
